<UserControl x:Class="DDiary.Views.DiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DDiary.ViewModels"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Classic Table DataGrid style -->
        <Style x:Key="ClassicDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource StripeBrush}"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style x:Key="ClassicColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource TableHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ClassicCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEditing" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Diary Header (date + save only) ── -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="16,12,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Style="{StaticResource SectionHeaderStyle}"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Text="{Binding Date, StringFormat='Diario del {0:dddd dd MMMM yyyy}'}"/>

                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveDiaryCommand}"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                    💾 Salva
                </Button>
            </Grid>
        </Border>

        <!-- ── Main Content: Modern View OR Classic View ── -->

        <!-- MODERN VIEW -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,0,16,16"
                      Visibility="{Binding IsClassicMode, Converter={StaticResource InvBoolVis}}">
            <StackPanel>
            <ItemsControl ItemsSource="{Binding MealSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MealSectionViewModel}">
                        <Border Style="{StaticResource CardStyle}"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Meal Section Header -->
                                <Border Grid.Row="0"
                                        Background="{DynamicResource TableHeaderBrush}"
                                        CornerRadius="6,6,0,0"
                                        Padding="12,8"
                                        Margin="-16,-16,-16,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding MealTypeLabel}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AccentBrush}"/>

                                        <TextBlock Grid.Column="1"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run Text="Totale CHO: "/>
                                            <Run Text="{Binding TotalCho, StringFormat='{}{0:F1} g'}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- Glycemia + Insulin row -->
                                <Grid Grid.Row="1" Margin="0,12,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Glicemia prima (mg/dL)"/>
                                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding GlycemiaBefore, StringFormat='{}{0:F0}', TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="4,0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Glicemia dopo (mg/dL)"/>
                                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding GlycemiaAfter, StringFormat='{}{0:F0}', TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="4,0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Unità Insulina"/>
                                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding InsulinCarbRatio, StringFormat='{}{0:F1}', UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="4,0,0,0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Note pasto"/>
                                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Food entries table header -->
                                <Border Grid.Row="2"
                                        Background="{DynamicResource StripeBrush}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        Margin="0,0,0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Alimento" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="Porzione (g)" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="CHO (g)" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="Ora" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Food entries list -->
                                <ItemsControl Grid.Row="3" ItemsSource="{Binding FoodEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:FoodEntryViewModel}">
                                            <Border Padding="8,5"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="36"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding PortionGrams, StringFormat='{}{0:F0}', UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             HorizontalContentAlignment="Right"
                                                             VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding ChoGrams, StringFormat='{}{0:F1}', UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             HorizontalContentAlignment="Right"
                                                             VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding MealTimeDisplay}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="12"/>

                                                    <!-- Delete button -->
                                                    <Button Grid.Column="4"
                                                            Width="28" Height="28"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            ToolTip="Elimina"
                                                            Command="{Binding DataContext.DeleteFoodEntryCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Id}">
                                                        <TextBlock Text="✕" FontSize="11" Foreground="{DynamicResource ErrorBrush}"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add inline row button — iOS 26 ghost style -->
                                <Button Grid.Row="4"
                                        HorizontalAlignment="Center"
                                        Margin="0,10,0,0"
                                        Padding="20,6"
                                        FontSize="12"
                                        Cursor="Hand"
                                        ToolTip="Aggiungi una riga vuota"
                                        Command="{Binding DataContext.AddInlineFoodEntryCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding MealType}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Opacity" Value="0.35"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="20"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="Opacity" Value="1.0"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="＋" FontSize="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Aggiungi riga"/>
                                    </StackPanel>
                                </Button>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Attività fisica + Nota del giorno (scrollable, below meals) ── -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="🏃 Attività fisica"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding PhysicalActivityNotes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Descrivi l'attività fisica svolta oggi"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="📌 Nota importante del giorno"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Compleanno, festa, cinema, acquapark, eventi speciali..."/>
                    </StackPanel>
                </Grid>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- CLASSIC TABLE VIEW -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,0,16,16"
                      Visibility="{Binding IsClassicMode, Converter={StaticResource BoolVis}}">
            <StackPanel HorizontalAlignment="Stretch">
            <TextBlock Text="Tabella Diario — Vista classica"
                       Style="{StaticResource SectionHeaderStyle}"
                       FontSize="15"
                       Margin="0,8,0,8"/>

            <!-- Hierarchical classic table: one block per meal section -->
            <ItemsControl ItemsSource="{Binding MealSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MealSectionViewModel}">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,0,10"
                                Background="{DynamicResource SurfaceBrush}">
                            <StackPanel>

                                <!-- ── Meal-type header (divider) ── -->
                                <Border Background="{DynamicResource AccentBrush}"
                                        CornerRadius="3,3,0,0"
                                        Padding="10,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding MealTypeLabel}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="White"/>
                                        <TextBlock Grid.Column="1"
                                                   FontSize="12"
                                                   Foreground="#CCFFFFFF">
                                            <Run Text="Totale CHO: "/>
                                            <Run Text="{Binding TotalCho, StringFormat='{}{0:F1} g'}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- ── Meal-level editable fields row ── -->
                                <Border Background="{DynamicResource StripeBrush}"
                                        Padding="8,6"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Glicemia prima -->
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Glicemia prima (mg/dL)"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding GlycemiaBefore, StringFormat='{}{0:F0}', TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     FontSize="12"
                                                     Padding="4,3"/>
                                        </StackPanel>

                                        <!-- Glicemia dopo -->
                                        <StackPanel Grid.Column="1" Margin="4,0">
                                            <TextBlock Text="Glicemia dopo (mg/dL)"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding GlycemiaAfter, StringFormat='{}{0:F0}', TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     FontSize="12"
                                                     Padding="4,3"/>
                                        </StackPanel>

                                        <!-- Unità Insulina -->
                                        <StackPanel Grid.Column="2" Margin="4,0">
                                            <TextBlock Text="Unità Insulina"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding InsulinCarbRatio, StringFormat='{}{0:F1}', UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     FontSize="12"
                                                     Padding="4,3"/>
                                        </StackPanel>

                                        <!-- Note pasto -->
                                        <StackPanel Grid.Column="3" Margin="4,0,0,0">
                                            <TextBlock Text="Note pasto"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     FontSize="12"
                                                     Padding="4,3"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- ── Food entries column header ── -->
                                <Border Background="{DynamicResource TableHeaderBrush}"
                                        Padding="8,4"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Alimento" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="Porzione (g)" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="CHO (g)" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="Ora" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- ── Food entry rows ── -->
                                <ItemsControl ItemsSource="{Binding FoodEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:FoodEntryViewModel}">
                                            <Border Padding="8,5"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Background="{DynamicResource BackgroundBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="36"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             FontSize="12"
                                                             VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding PortionGrams, StringFormat='{}{0:F0}', UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             FontSize="12"
                                                             HorizontalContentAlignment="Right"
                                                             VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding ChoGrams, StringFormat='{}{0:F1}', UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             FontSize="12"
                                                             HorizontalContentAlignment="Right"
                                                             VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding MealTimeDisplay}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="12"/>

                                                    <!-- Delete button -->
                                                    <Button Grid.Column="4"
                                                            Width="28" Height="28"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            ToolTip="Elimina"
                                                            Command="{Binding DataContext.DeleteFoodEntryCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Id}">
                                                        <TextBlock Text="✕" FontSize="11" Foreground="{DynamicResource ErrorBrush}"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- ── Add food entry button ── -->
                                <Border Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}">
                                    <Button HorizontalAlignment="Center"
                                            Padding="20,5"
                                            FontSize="12"
                                            Cursor="Hand"
                                            ToolTip="Aggiungi una riga vuota"
                                            Command="{Binding DataContext.AddInlineFoodEntryCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding MealType}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Opacity" Value="0.45"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="20"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="Opacity" Value="1.0"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="＋" FontSize="14" Margin="0,0,5,0"/>
                                            <TextBlock Text="Aggiungi alimento"/>
                                        </StackPanel>
                                    </Button>
                                </Border>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Attività fisica + Nota del giorno (below classic table) ── -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="🏃 Attività fisica"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding PhysicalActivityNotes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Descrivi l'attività fisica svolta oggi"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="📌 Nota importante del giorno"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Compleanno, festa, cinema, acquapark, eventi speciali..."/>
                    </StackPanel>
                </Grid>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource OverlayBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="6"/>
