<UserControl x:Class="DDiary.Views.DiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DDiary.ViewModels"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Time Picker Box Style (matches ModernTextBoxStyle) -->
        <Style x:Key="TimePickerBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Classic Table DataGrid style -->
        <Style x:Key="ClassicDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource StripeBrush}"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style x:Key="ClassicColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource TableHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ClassicCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEditing" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Meal section card: no inner padding so header fills edge-to-edge -->
        <Style x:Key="MealSectionCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <!-- Compact header label style for food-entry table columns -->
        <Style x:Key="TableHeaderLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Diary Header (date + save only) ── -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="16,12,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Style="{StaticResource SectionHeaderStyle}"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Text="{Binding Date, StringFormat='Diario del {0:dddd dd MMMM yyyy}'}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding DataContext.CopyScreenshotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ToolTip="Copia screenshot negli appunti">
                        <TextBlock Text="📷"/>
                    </Button>

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding DataContext.ToggleFullscreenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ToolTip="Schermo intero / Ripristina">
                        <TextBlock Text="{Binding DataContext.FullscreenLabel, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Button>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveDiaryCommand}"
                            VerticalAlignment="Center">
                        💾 Salva
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main Content: Modern View OR Classic View ── -->

        <!-- MODERN VIEW -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,0,16,16"
                      Visibility="{Binding IsClassicMode, Converter={StaticResource InvBoolVis}}">
            <StackPanel>
            <ItemsControl ItemsSource="{Binding MealSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MealSectionViewModel}">
                        <Border Style="{StaticResource MealSectionCardStyle}"
                                Margin="0,0,0,10">
                            <StackPanel>

                                <!-- ── Section header (clickable toggle) ── -->
                                <Border Cursor="Hand" Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource TableHeaderBrush}"/>
                                            <Setter Property="CornerRadius" Value="10,10,0,0"/>
                                            <Style.Triggers>
                                                <!-- Collapsed → fully rounded -->
                                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </DataTrigger>
                                                <!-- Empty + collapsed → lighter colour -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasFoodEntries}" Value="False"/>
                                                        <Condition Binding="{Binding IsExpanded}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="{DynamicResource EmptySectionHeaderBrush}"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleSectionCommand}"/>
                                    </Border.InputBindings>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Chevron indicator (▶ rotated when expanded) -->
                                        <TextBlock Grid.Column="0"
                                                   Text="▶"
                                                   FontSize="10"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Meal type label -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding MealTypeLabel}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Style.Triggers>
                                                        <!-- Empty + collapsed → muted label -->
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding HasFoodEntries}" Value="False"/>
                                                                <Condition Binding="{Binding IsExpanded}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- CHO total -->
                                        <TextBlock Grid.Column="2"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="Totale CHO: "/>
                                            <Run Text="{Binding TotalCho, StringFormat='{}{0:F1} g'}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- ── Collapsible content ── -->
                                <StackPanel Margin="16,12,16,16"
                                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}">

                                    <!-- Glycemia + Insulin row -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Glicemia prima (mg/dL)"/>
                                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                                     Text="{Binding GlycemiaBefore, StringFormat='{}{0:F0}', TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="4,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Glicemia dopo (mg/dL)"/>
                                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                                     Text="{Binding GlycemiaAfter, StringFormat='{}{0:F0}', TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="4,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Unità Insulina"/>
                                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                                     Text="{Binding InsulinCarbRatio, StringFormat='{}{0:F1}', UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <!-- Ora pasto -->
                                        <StackPanel Grid.Column="3" Margin="4,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Ora pasto"/>

                                            <Grid>
                                                <Border x:Name="TimePickerBox"
                                                        Margin="0,0,0,0"
                                                        Style="{StaticResource TimePickerBoxStyle}">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick" 
                                                                      Command="{Binding OpenTimePickerCommand}"/>
                                                    </Border.InputBindings>
                                                    <TextBlock Text="{Binding MealTimeText}"
                                                               FontSize="14"
                                                               TextAlignment="Center"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Popup time picker -->
                                                <Popup x:Name="TimePickerPopup"
                                                       IsOpen="{Binding IsTimePickerOpen, Mode=TwoWay}"
                                                       Placement="Center"
                                                       StaysOpen="True"
                                                       AllowsTransparency="True"
                                                       PopupAnimation="Fade"
                                                       Margin="0">
                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="16"
                                                            Effect="{StaticResource ShadowEffect}">
                                                        <Grid Width="240">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Title -->
                                                            <TextBlock Grid.Row="0"
                                                                       Text="Seleziona ora"
                                                                       FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       Margin="0,0,0,12"/>

                                                            <!-- Time Spinner -->
                                                            <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Hours -->
                                                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                                    <Button Content="▲" 
                                                                            Style="{StaticResource SpinnerButtonStyle}"
                                                                            Command="{Binding IncrementHourCommand}"
                                                                            Margin="0,0,0,4"/>
                                                                    <TextBlock Text="{Binding MealHourDisplay}" 
                                                                               FontSize="28" FontWeight="Bold"
                                                                               TextAlignment="Center"
                                                                               Foreground="{DynamicResource AccentBrush}"
                                                                               Padding="12,8"/>
                                                                    <Button Content="▼" 
                                                                            Style="{StaticResource SpinnerButtonStyle}"
                                                                            Command="{Binding DecrementHourCommand}"
                                                                            Margin="0,4,0,0"/>
                                                                </StackPanel>

                                                                <!-- Divider -->
                                                                <TextBlock Grid.Column="1" Text=":" 
                                                                           FontSize="28" FontWeight="Bold"
                                                                           Padding="8,0"
                                                                           Foreground="{DynamicResource AccentBrush}"
                                                                           VerticalAlignment="Center"/>

                                                                <!-- Minutes -->
                                                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                                    <Button Content="▲" 
                                                                            Style="{StaticResource SpinnerButtonStyle}"
                                                                            Command="{Binding IncrementMinuteCommand}"
                                                                            Margin="0,0,0,4"/>
                                                                    <TextBlock Text="{Binding MealMinuteDisplay}" 
                                                                               FontSize="28" FontWeight="Bold"
                                                                               TextAlignment="Center"
                                                                               Foreground="{DynamicResource AccentBrush}"
                                                                               Padding="12,8"/>
                                                                    <Button Content="▼" 
                                                                            Style="{StaticResource SpinnerButtonStyle}"
                                                                            Command="{Binding DecrementMinuteCommand}"
                                                                            Margin="0,4,0,0"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Buttons -->
                                                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                                        Content="Annulla"
                                                                        Command="{Binding CancelTimePickerCommand}"
                                                                        Padding="12,6"
                                                                        FontSize="12"
                                                                        Margin="0,0,8,0"/>

                                                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                                                        Content="OK"
                                                                        Command="{Binding ConfirmTimePickerCommand}"
                                                                        Padding="12,6"
                                                                        FontSize="12"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Margin="4,0,0,0">
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="Note pasto"/>
                                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Food entries table header -->
                                    <Border Background="{DynamicResource StripeBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource TableHeaderLabelStyle}" Text="Alimento"/>
                                            <TextBlock Grid.Column="1" Style="{StaticResource TableHeaderLabelStyle}" Text="Porzione (g)" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="2" Style="{StaticResource TableHeaderLabelStyle}" Text="CHO (g)" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <!-- Food entries list -->
                                    <ItemsControl ItemsSource="{Binding FoodEntries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:FoodEntryViewModel}">
                                                <Border Padding="8,5"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="36"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox Grid.Column="0"
                                                                 Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 VerticalAlignment="Center"/>

                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding PortionGrams, StringFormat='{}{0:F0}', UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 HorizontalContentAlignment="Right"
                                                                 VerticalAlignment="Center"/>

                                                        <TextBox Grid.Column="2"
                                                                 Text="{Binding ChoGrams, StringFormat='{}{0:F1}', UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 HorizontalContentAlignment="Right"
                                                                 VerticalAlignment="Center"/>

                                                        <!-- Delete button -->
                                                        <Button Grid.Column="3"
                                                                Width="28" Height="28"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                ToolTip="Elimina"
                                                                Command="{Binding DataContext.DeleteFoodEntryCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding Id}">
                                                            <TextBlock Text="✕" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Add inline row button — iOS 26 ghost style -->
                                    <Button HorizontalAlignment="Center"
                                            Margin="0,10,0,0"
                                            Padding="20,6"
                                            FontSize="13"
                                            Cursor="Hand"
                                            ToolTip="Aggiungi una riga vuota"
                                            Command="{Binding DataContext.AddInlineFoodEntryCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding MealType}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Opacity" Value="0.35"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="20"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="Opacity" Value="1.0"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="＋" FontSize="14" Margin="0,0,5,0"/>
                                            <TextBlock Text="Aggiungi riga"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Attività fisica + Nota del giorno (scrollable, below meals) ── -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="🏃 Attività fisica"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding PhysicalActivityNotes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Descrivi l'attività fisica svolta oggi"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="📌 Nota importante del giorno"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Compleanno, festa, cinema, acquapark, eventi speciali..."/>
                    </StackPanel>
                </Grid>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- CLASSIC TABLE VIEW -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,0,16,16"
                      Visibility="{Binding IsClassicMode, Converter={StaticResource BoolVis}}">
            <StackPanel HorizontalAlignment="Stretch">
            <TextBlock Text="Tabella Diario — Vista classica"
                       Style="{StaticResource SectionHeaderStyle}"
                       FontSize="15"
                       Margin="0,8,0,8"/>

            <!-- Hierarchical classic table: one block per meal section -->
            <ItemsControl ItemsSource="{Binding MealSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MealSectionViewModel}">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,0,10"
                                Background="{DynamicResource SurfaceBrush}">
                            <StackPanel>

                                <!-- ── Meal-type header (divider) ── -->
                                <Border Background="{DynamicResource AccentBrush}"
                                        CornerRadius="3,3,0,0"
                                        Padding="10,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding MealTypeLabel}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="White"/>
                                        <TextBlock Grid.Column="1"
                                                   FontSize="12"
                                                   Foreground="#CCFFFFFF">
                                            <Run Text="Totale CHO: "/>
                                            <Run Text="{Binding TotalCho, StringFormat='{}{0:F1} g'}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- ── Meal-level editable fields row ── -->
                                <Border Background="{DynamicResource StripeBrush}"
                                        Padding="8,6"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Glicemia prima -->
                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                            <TextBlock Text="Glicemia prima (mg/dL)"
                                                       Style="{StaticResource TableHeaderLabelStyle}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding GlycemiaBefore, StringFormat='{}{0:F0}', TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     Padding="4,3"/>
                                        </StackPanel>

                                        <!-- Glicemia dopo -->
                                        <StackPanel Grid.Column="1" Margin="4,0">
                                            <TextBlock Text="Glicemia dopo (mg/dL)"
                                                       Style="{StaticResource TableHeaderLabelStyle}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding GlycemiaAfter, StringFormat='{}{0:F0}', TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     Padding="4,3"/>
                                        </StackPanel>

                                        <!-- Unità Insulina -->
                                        <StackPanel Grid.Column="2" Margin="4,0">
                                            <TextBlock Text="Unità Insulina"
                                                       Style="{StaticResource TableHeaderLabelStyle}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding InsulinCarbRatio, StringFormat='{}{0:F1}', UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     Padding="4,3"/>
                                        </StackPanel>

                                        <!-- Ora pasto -->
                                        <StackPanel Grid.Column="3" Margin="4,0">
                                            <TextBlock Text="Ora pasto"
                                                       Style="{StaticResource TableHeaderLabelStyle}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Style="{StaticResource TimePickerStyle}"
                                                     Text="{Binding MealTimeText, UpdateSourceTrigger=LostFocus}"
                                                     Padding="4,3"/>
                                        </StackPanel>

                                        <!-- Note pasto -->
                                        <StackPanel Grid.Column="4" Margin="4,0,0,0">
                                            <TextBlock Text="Note pasto"
                                                       Style="{StaticResource TableHeaderLabelStyle}"
                                                       Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     Padding="4,3"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- ── Food entries column header ── -->
                                <Border Background="{DynamicResource TableHeaderBrush}"
                                        Padding="8,4"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource TableHeaderLabelStyle}" Text="Alimento"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource TableHeaderLabelStyle}" Text="Porzione (g)" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Style="{StaticResource TableHeaderLabelStyle}" Text="CHO (g)" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <!-- ── Food entry rows ── -->
                                <ItemsControl ItemsSource="{Binding FoodEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:FoodEntryViewModel}">
                                            <Border Padding="8,5"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Background="{DynamicResource BackgroundBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="36"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding PortionGrams, StringFormat='{}{0:F0}', UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             HorizontalContentAlignment="Right"
                                                             VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding ChoGrams, StringFormat='{}{0:F1}', UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             HorizontalContentAlignment="Right"
                                                             VerticalAlignment="Center"/>

                                                    <!-- Delete button -->
                                                    <Button Grid.Column="3"
                                                            Width="28" Height="28"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            ToolTip="Elimina"
                                                            Command="{Binding DataContext.DeleteFoodEntryCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Id}">
                                                        <TextBlock Text="✕" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- ── Add food entry button ── -->
                                <Border Padding="8,6"
                                        Background="{DynamicResource BackgroundBrush}">
                                    <Button HorizontalAlignment="Center"
                                            Padding="20,5"
                                            FontSize="12"
                                            Cursor="Hand"
                                            ToolTip="Aggiungi una riga vuota"
                                            Command="{Binding DataContext.AddInlineFoodEntryCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding MealType}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Opacity" Value="0.45"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="20"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="Opacity" Value="1.0"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="＋" FontSize="14" Margin="0,0,5,0"/>
                                            <TextBlock Text="Aggiungi alimento"/>
                                        </StackPanel>
                                    </Button>
                                </Border>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Attività fisica + Nota del giorno (below classic table) ── -->
            <Border Style="{StaticResource CardStyle}"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="🏃 Attività fisica"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding PhysicalActivityNotes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Descrivi l'attività fisica svolta oggi"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="📌 Nota importante del giorno"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False"
                                 ToolTip="Compleanno, festa, cinema, acquapark, eventi speciali..."/>
                    </StackPanel>
                </Grid>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource OverlayBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="6"/>
                <TextBlock Text="Caricamento..." HorizontalAlignment="Center" Margin="0,8,0,0"
                           Foreground="White" FontSize="14"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
