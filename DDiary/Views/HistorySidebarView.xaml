<UserControl x:Class="DDiary.Views.HistorySidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DDiary.ViewModels"
             mc:Ignorable="d"
             Width="280"
             Background="{DynamicResource SidebarBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,12,12,8">
            <StackPanel>
                <TextBlock Text="📂 Storico diari"
                           Style="{StaticResource SectionHeaderStyle}"
                           FontSize="15"/>

                <!-- Search box -->
                <TextBox Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,6,0,6">
                    <TextBox.Resources>
                        <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}"/>
                    </TextBox.Resources>
                </TextBox>

                <!-- Filters row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              Style="{StaticResource ModernComboBoxStyle}"
                              SelectedValue="{Binding FilterYear}"
                              Margin="0,0,3,0"
                              ToolTip="Filtra per anno">
                        <ComboBox.Items>
                            <ComboBoxItem Content="Anno" IsSelected="True"/>
                        </ComboBox.Items>
                    </ComboBox>

                    <ComboBox Grid.Column="1"
                              Style="{StaticResource ModernComboBoxStyle}"
                              SelectedValue="{Binding FilterMonth}"
                              Margin="3,0,0,0"
                              ToolTip="Filtra per mese">
                        <ComboBox.Items>
                            <ComboBoxItem Content="Mese" IsSelected="True"/>
                            <ComboBoxItem Content="Gennaio" Tag="1"/>
                            <ComboBoxItem Content="Febbraio" Tag="2"/>
                            <ComboBoxItem Content="Marzo" Tag="3"/>
                            <ComboBoxItem Content="Aprile" Tag="4"/>
                            <ComboBoxItem Content="Maggio" Tag="5"/>
                            <ComboBoxItem Content="Giugno" Tag="6"/>
                            <ComboBoxItem Content="Luglio" Tag="7"/>
                            <ComboBoxItem Content="Agosto" Tag="8"/>
                            <ComboBoxItem Content="Settembre" Tag="9"/>
                            <ComboBoxItem Content="Ottobre" Tag="10"/>
                            <ComboBoxItem Content="Novembre" Tag="11"/>
                            <ComboBoxItem Content="Dicembre" Tag="12"/>
                        </ComboBox.Items>
                    </ComboBox>
                </Grid>

                <!-- Sort + Clear -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              Style="{StaticResource ModernCheckBoxStyle}"
                              Content="Più recenti prima"
                              IsChecked="{Binding SortNewest}"
                              VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Pulisci"
                            Command="{Binding ClearFiltersCommand}"
                            Padding="8,4"
                            FontSize="11"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Go to Today button -->
        <Button Grid.Row="1"
                Style="{StaticResource PrimaryButtonStyle}"
                Content="📅 Vai ad oggi"
                Command="{Binding GoToTodayCommand}"
                Margin="12,8"
                HorizontalAlignment="Stretch"/>

        <!-- Diary list -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}}">
                <TextBlock Text="📭" FontSize="36" HorizontalAlignment="Center"/>
                <TextBlock Text="Nessun diario trovato"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- List -->
            <ListBox ItemsSource="{Binding Diaries}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolVis}}"
                     SelectionChanged="DiaryList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DiaryHistoryItemViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ShortDate}"
                                           FontWeight="{Binding IsToday, Converter={StaticResource BoolToWeight}}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="{Binding FoodEntriesCount}"/>
                                    <Run Text=" alimenti · CHO:"/>
                                    <Run Text="{Binding TotalDayCho, StringFormat='{}{0:F0}'}"/>
                                    <Run Text="g"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Today badge -->
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="4"
                                    Padding="4,2"
                                    Visibility="{Binding IsToday, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="oggi" FontSize="10" Foreground="White"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Grid>
</UserControl>
