<UserControl x:Class="DDiary.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DDiary.ViewModels"
             xmlns:models="clr-namespace:DDiary.Models"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="👤 Profili utente"
                   Style="{StaticResource SectionHeaderStyle}"
                   FontSize="22"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Profile List -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Profili locali" Style="{StaticResource SectionHeaderStyle}"/>
                    <Separator/>

                    <ListBox ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,8,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:UserProfile}">
                                <!-- Note: UserProfile is a model, we reference directly -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Content="Usa"
                                            Padding="8,4"
                                            FontSize="11"
                                            Command="{Binding DataContext.SelectProfileCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Create new profile -->
                    <Separator/>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Nuovo profilo" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="+"
                                Margin="6,0,0,0"
                                Command="{Binding CreateProfileCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Profile Details -->
            <Border Grid.Column="1"
                    Style="{StaticResource CardStyle}"
                    Margin="12,0,0,0">
                <StackPanel>
                    <TextBlock Text="Dettagli profilo" Style="{StaticResource SectionHeaderStyle}"/>
                    <Separator/>

                    <StackPanel IsEnabled="{Binding SelectedProfile, Converter={StaticResource NullToBool}}"
                                Margin="0,8,0,0">

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Nome visualizzato"/>
                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding SelectedProfile.DisplayName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Lingua preferita"/>
                                <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                         Text="{Binding SelectedProfile.PreferredLanguage, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Tema preferito"/>
                                <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                                          ItemsSource="{Binding ThemeOptions}"
                                          SelectedItem="{Binding SelectedProfile.PreferredTheme, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Creato il"/>
                            <TextBlock Text="{Binding SelectedProfile.CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Content="💾 Salva profilo"
                                Command="{Binding SaveProfileCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,16,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
