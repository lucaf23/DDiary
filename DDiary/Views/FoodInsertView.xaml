<UserControl x:Class="DDiary.Views.FoodInsertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DDiary.ViewModels"
             mc:Ignorable="d"
             KeyDown="UserControl_KeyDown"
             Focusable="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <Style x:Key="SpinnerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource StripeBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TimeValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="MinWidth" Value="38"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- Title -->
        <TextBlock Text="➕ Aggiungi alimento"
                   Style="{StaticResource SectionHeaderStyle}"
                   FontSize="18"
                   Margin="0,0,0,16"/>

        <!-- Time row -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Hour/Minute Spinner -->
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Style="{StaticResource LabelStyle}" Text="Ora pasto *"/>
                <Border Style="{StaticResource CardStyle}"
                        Padding="8,6"
                        Margin="0,2,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <!-- Hour spinner -->
                        <StackPanel>
                            <Button Style="{StaticResource SpinnerButtonStyle}"
                                    Command="{Binding IncrementHourCommand}"
                                    Content="▲"/>
                            <TextBlock Style="{StaticResource TimeValueStyle}"
                                       Text="{Binding MealHourDisplay}"
                                       Margin="0,4"/>
                            <Button Style="{StaticResource SpinnerButtonStyle}"
                                    Command="{Binding DecrementHourCommand}"
                                    Content="▼"/>
                        </StackPanel>

                        <!-- Separator -->
                        <TextBlock Text=":"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="4,0"/>

                        <!-- Minute spinner -->
                        <StackPanel>
                            <Button Style="{StaticResource SpinnerButtonStyle}"
                                    Command="{Binding IncrementMinuteCommand}"
                                    Content="▲"/>
                            <TextBlock Style="{StaticResource TimeValueStyle}"
                                       Text="{Binding MealMinuteDisplay}"
                                       Margin="0,4"/>
                            <Button Style="{StaticResource SpinnerButtonStyle}"
                                    Command="{Binding DecrementMinuteCommand}"
                                    Content="▼"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
                <TextBlock Text="{Binding TimeError}"
                           Style="{StaticResource ErrorTextStyle}"
                           Visibility="{Binding TimeError, Converter={StaticResource StrVis}}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Style="{StaticResource LabelStyle}" Text="Tipo Pasto"/>
                <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                          ItemsSource="{Binding MealTypeOptions}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedMealTypeOption}"/>
            </StackPanel>
        </Grid>

        <!-- Food name -->
        <StackPanel Margin="0,0,0,12">
            <TextBlock Style="{StaticResource LabelStyle}" Text="Nome alimento *"/>
            <TextBox x:Name="FoodNameBox"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding FoodName, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="{Binding NameError}"
                       Style="{StaticResource ErrorTextStyle}"
                       Visibility="{Binding NameError, Converter={StaticResource StrVis}}"/>
        </StackPanel>

        <!-- Grams + CHO row -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Style="{StaticResource LabelStyle}" Text="Porzione (g)"/>
                <TextBox Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding PortionGramsText, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="{Binding GramsError}"
                           Style="{StaticResource ErrorTextStyle}"
                           Visibility="{Binding GramsError, Converter={StaticResource StrVis}}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Style="{StaticResource LabelStyle}" Text="CHO (g)"/>
                <TextBox Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding ChoGramsText, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="{Binding ChoError}"
                           Style="{StaticResource ErrorTextStyle}"
                           Visibility="{Binding ChoError, Converter={StaticResource StrVis}}"/>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Content="Annulla"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,8,0"/>

            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Content="Salva e aggiungi altro"
                    Command="{Binding SaveAndAddCommand}"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsValid}"/>

            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Content="Salva"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsValid}"/>
        </StackPanel>

    </StackPanel>
</UserControl>
